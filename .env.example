# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SCRAPER CONFIGURATION
# Set your ZenRows API key (zenrows.com) or ScraperAPI key (scraperapi.com) to bypass Netlify/Cloud IP blocks
# Add this via the Environment Variables / Secrets panel
ZENROWS_API_KEY=
SCRAPER_API_KEY=
# Set your proxy URL if you have one (e.g., http://user:pass@proxy.example.com:8080)
# PROXY_URL=
# USER_AGENT_OVERRIDE=

# EXCEL EXPORT SETTINGS
EXCEL_FILENAME="leads_export.xlsx"
